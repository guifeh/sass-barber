DATABASE_URL=postgres://postgres:postgres@localhost:5432/sass_barber
PORT=3333
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

